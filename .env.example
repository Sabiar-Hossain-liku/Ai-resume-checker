# Environment variables
# Copy this to .env and fill in your values — DO NOT commit .env to git

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/prepai

# Auth
JWT_SECRET=change_this_to_a_long_random_secret_string

# Groq AI (free tier, get key at: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=https://your-app.vercel.app

# Server
PORT=3000
NODE_ENV=development
